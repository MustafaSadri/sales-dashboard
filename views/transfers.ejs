<!DOCTYPE html>
<html>
<head>
  <title>Transfers — Sales Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    :root {
      --bg: #f0f4f8;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --text: #111827;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --topbar: rgba(255,255,255,0.88);
      --card-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
      --hover-shadow: 0 8px 28px rgba(0,0,0,0.1);
      --accent: #4f46e5;
      --purple: #7c3aed;
      --radius: 18px;
    }
    [data-theme="dark"] {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #21262d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --border: #30363d;
      --topbar: rgba(22,27,34,0.92);
      --card-shadow: 0 2px 12px rgba(0,0,0,0.35);
      --hover-shadow: 0 8px 28px rgba(0,0,0,0.5);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'Segoe UI', BlinkMacSystemFont, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      transition: background 0.25s, color 0.25s;
    }

    .topbar {
      position: sticky; top: 0; z-index: 100;
      background: var(--topbar);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      height: 56px;
      display: flex; align-items: center;
      padding: 0 20px;
    }
    .topbar-inner {
      width: 100%; max-width: 640px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .brand {
      font-size: 16px; font-weight: 700; letter-spacing: -0.4px;
      display: flex; align-items: center; gap: 8px;
    }
    .brand-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--purple); display: inline-block; }
    .topbar-right { display: flex; align-items: center; gap: 8px; }

    .nav-link {
      font-size: 13px; font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 8px;
      background: rgba(79,70,229,0.08);
      transition: background 0.2s;
    }
    .nav-link:hover { background: rgba(79,70,229,0.16); }

    .theme-btn {
      width: 38px; height: 38px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 17px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, transform 0.15s;
    }
    .theme-btn:hover { background: var(--surface2); transform: scale(1.05); }

    .main {
      max-width: 640px;
      margin: 0 auto;
      padding: 24px 16px 60px;
    }

    .page-title { font-size: 26px; font-weight: 800; letter-spacing: -0.6px; margin-bottom: 4px; }
    .page-sub {
      font-size: 13px; color: var(--text-muted);
      display: flex; align-items: center; gap: 8px; margin-bottom: 22px;
    }
    .count-pill {
      background: var(--purple); color: #fff;
      font-size: 11px; font-weight: 700;
      padding: 2px 8px; border-radius: 20px;
    }

    .card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      border-left: 4px solid var(--purple);
      margin-bottom: 16px;
      box-shadow: var(--card-shadow);
      overflow: hidden;
      transition: transform 0.18s, box-shadow 0.18s;
    }
    .card:hover { transform: translateY(-2px); box-shadow: var(--hover-shadow); }

    .card-body { padding: 18px 18px 14px; }

    .card-top {
      display: flex; align-items: flex-start;
      justify-content: space-between; gap: 10px;
      margin-bottom: 14px;
    }
    .transfer-name { font-size: 17px; font-weight: 700; letter-spacing: -0.3px; }
    .date-chip {
      flex-shrink: 0;
      font-size: 11px; font-weight: 600;
      color: var(--text-muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 4px 10px; border-radius: 20px;
    }

    .route-row {
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
    }
    .route-warehouse {
      flex: 1;
    }
    .route-label {
      font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.6px;
      color: var(--text-muted); margin-bottom: 3px;
    }
    .route-name { font-size: 14px; font-weight: 600; }
    .route-arrow {
      font-size: 20px; color: var(--text-muted);
      flex-shrink: 0;
    }

    .card-footer {
      padding: 12px 18px;
      background: var(--surface2);
      border-top: 1px solid var(--border);
    }
    .btn {
      display: block;
      text-align: center;
      padding: 11px;
      border-radius: 10px;
      font-size: 13px; font-weight: 600;
      text-decoration: none;
      background: var(--purple); color: #fff;
      transition: opacity 0.2s, transform 0.1s;
    }
    .btn:hover { opacity: 0.88; }
    .btn:active { transform: scale(0.97); }

    .empty {
      text-align: center; padding: 80px 24px; color: var(--text-muted);
    }
    .empty-icon { font-size: 52px; margin-bottom: 14px; }
    .empty h3 { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  </style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <span class="brand-dot"></span>
      Transfers
    </div>
    <div class="topbar-right">
      <a href="/" class="nav-link">← Orders</a>
      <button class="theme-btn" id="themeBtn" onclick="toggleTheme()"></button>
    </div>
  </div>
</header>

<main class="main">
  <div class="page-title">Transfers</div>
  <div class="page-sub">
    <span class="count-pill"><%= transfers.length %></span>
    latest transfers
  </div>

  <% if (!transfers || transfers.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">📭</div>
      <h3>No transfers found</h3>
      <p>There are no recent warehouse transfers.</p>
    </div>
  <% } %>

  <% (transfers || []).forEach(function(transfer) { %>
  <div class="card">
    <div class="card-body">
      <div class="card-top">
        <div class="transfer-name"><%= transfer.name %></div>
        <span class="date-chip"><%= transfer.date %></span>
      </div>

      <div class="route-row">
        <div class="route-warehouse">
          <div class="route-label">From</div>
          <div class="route-name"><%= transfer.source || '—' %></div>
        </div>
        <div class="route-arrow">→</div>
        <div class="route-warehouse">
          <div class="route-label">To</div>
          <div class="route-name"><%= transfer.target || '—' %></div>
        </div>
      </div>
    </div>

    <div class="card-footer">
      <a class="btn" href="/transfer/<%= transfer.id %>">View Items</a>
    </div>
  </div>
  <% }); %>
</main>

<script>
  function setIcon() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
  }
  function toggleTheme() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    var next = dark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    setIcon();
  }
  setIcon();
</script>

</body>
</html>
