<!DOCTYPE html>
<html>
<head>
  <title>Orders</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "San Francisco", Arial;
      background: #f5f5f7;
      color: #1d1d1f;
    }

    .container {
      padding: 20px;
    }

    h2 {
      text-align: center;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .card {
      background: white;
      border-radius: 20px;
      padding: 15px;
      margin-bottom: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .row {
      display: flex;
      justify-content: space-between;
      margin-top: 6px;
      font-size: 14px;
    }

    .label {
      color: #6e6e73;
    }

    .value {
      font-weight: 600;
    }

    .status {
      padding: 4px 10px;
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
    }

    .accepted {
      background: #e6f4ea;
      color: #1e7e34;
    }

    .new {
      background: #fff3cd;
      color: #856404;
    }

    .ready {
      background: #e8f0fe;
      color: #174ea6;
    }

    .address-box {
      font-size: 12px;
      white-space: pre-line;
      background: #f2f2f7;
      padding: 10px;
      border-radius: 10px;
      margin-top: 8px;
    }

    .btn {
      display: block;
      text-align: center;
      background: #0071e3;
      color: white;
      padding: 10px;
      border-radius: 12px;
      text-decoration: none;
      margin-top: 12px;
      font-weight: 500;
    }

    .btn:hover {
      background: #005bb5;
    }

    .status-btn {
      background: #ff9500; /* Vibrant Apple Orange */
      color: white;
    }

    .status-btn:hover {
      background: #e68600;
    }

    .shipment-btn {
      background: #34c759; /* Vibrant Apple Green */
      color: white;
    }

    .shipment-btn:hover {
      background: #2dae4c;
    }

    .shipment-flag {
      margin-top: 12px;
      padding: 8px 10px;
      border-radius: 10px;
      background: #e6f4ea;
      color: #1e7e34;
      font-size: 13px;
      font-weight: 600;
      text-align: center;
    }

    .success-toast {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #34c759;
      color: white;
      padding: 15px 25px;
      border-radius: 12px;
      font-weight: 600;
      box-shadow: 0 10px 25px rgba(52,199,89,0.4);
      transition: opacity 0.5s ease, transform 0.5s ease;
      z-index: 1000;
      transform: translateY(0);
    }
    .success-toast.hide {
      opacity: 0;
      transform: translateY(-20px);
    }
  </style>
  <script>
  setTimeout(() => {
    location.reload();
  }, 30000); // reload every 30 seconds
</script>
</head>

<body>

<div class="container">

  <a href="/transfers" class="btn" style="display:inline-block; margin-bottom: 20px; font-size: 14px; padding: 8px 16px; background: #5856d6;">⇆ View Transfers</a>

  <h2>📦 Orders</h2>

  <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="success-toast" id="successToast"><%= successMessage %></div>
    <script>
      setTimeout(() => {
        const toast = document.getElementById('successToast');
        if(toast) {
          toast.classList.add('hide');
          setTimeout(() => toast.remove(), 500);
        }
      }, 12000);
    </script>
  <% } %>

  <% orders.forEach(order => { %>

    <div class="card">
      <!-- Order + Status -->
      <div class="row">
        <span class="value"><%= order.name %></span>

        <span class="status 
          <%= order.status === 'ACCEPTED' ? 'accepted' : (order.status === 'READY TO DISPATCH' ? 'ready' : 'new') %>">
          <%= order.status %>
        </span>
      </div>

      <!-- Date (ONLY DATE) -->
      <%
        const d = new Date(order.date);
        const onlyDate =
          String(d.getDate()).padStart(2, "0") + "." +
          String(d.getMonth() + 1).padStart(2, "0") + "." +
          d.getFullYear();
      %>

      <div class="row">
        <span class="label">Date Created</span>
        <span class="value"><%= onlyDate %></span>
      </div>

      <!-- Counterparty -->
      <div class="row">
        <span class="label">Counterparty</span>
        <span class="value"><%= order.counterparty %></span>
      </div>

      <!-- Owner -->
      <div class="row">
        <span class="label">Owner</span>
        <span class="value"><%= order.owner %></span>
      </div>

      <!-- Total Quantity -->
      <div class="row">
        <span class="label">Total Quantity</span>
        <span class="value"><%= order.totalQty %> pcs</span>
      </div>

      <!-- Shipping Address -->
      <div style="margin-top:10px;">
        <div class="label">Shipping Address</div>
        <div class="address-box">
          <%= order.shippingAddress || "No address available" %>
        </div>
      </div>

        <!-- Button -->
        <a class="btn" href="/order/<%= order.id %>">
          View Packing
        </a>

        <% if (order.nextStatus) { %>
          <a class="btn status-btn" href="/confirm-status/<%= order.id %>/<%= encodeURIComponent(order.nextStatus) %>" onclick="this.style.pointerEvents='none'; this.innerText='Loading...'; this.style.opacity='0.7';">
            <%= order.statusActionLabel %>
          </a>
        <% } %>

    </div>

  <% }) %>

</div>

<style>
.btn-create-shipment-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  width: 100px;
  height: 100px;
  border-radius: 20px;
  background: #34c759;
  color: white;
  text-decoration: none;
  font-weight: bold;
  font-size: 14px;
  box-shadow: 0 4px 10px rgba(52,199,89,0.4);
  transition: transform 0.2s;
  line-height: 1.4;
}
.btn-create-shipment-circle:hover {
  transform: scale(1.05);
  background: #2dae4c;
}
</style>

</body>
</html>
