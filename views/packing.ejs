<!DOCTYPE html>
<html>
<head>
  <title>Packing List</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: -apple-system, Arial;
      background: #f5f5f7;
      padding: 15px;
    }

    h2 {
      text-align: center;
      margin-bottom: 10px;
    }

    .top-box {
      background: white;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 12px;
    }

    .label {
      font-size: 12px;
      color: #6e6e73;
      margin-top: 6px;
    }

    .value {
      font-weight: 600;
    }

    .address {
      font-size: 12px;
      white-space: pre-line;
      background: #f2f2f7;
      padding: 8px;
      border-radius: 8px;
      margin-top: 5px;
    }

    .btn-bar {
      display: flex;
      gap: 10px;
      margin: 10px 0 15px 0;
    }

    .btn {
      padding: 8px 14px;
      background: #0071e3;
      color: white;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-size: 14px;
      text-decoration: none;
    }

    .card {
      background: white;
      border-radius: 10px;
      padding: 10px;
      margin-bottom: 8px;
    }

    .row {
      display: flex;
      justify-content: space-between;
    }

    .product {
      font-size: 13px;
      max-width: 70%;
    }

    .qty {
      font-weight: bold;
    }

    @media print {
      .btn-bar {
        display: none;
      }
    }
  </style>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

</head>

<body>

<!-- ✅ BUTTONS -->
<div class="btn-bar">
  <button class="btn" onclick="window.print()">🖨️ Print</button>
  <button class="btn" onclick="downloadPDF()">⬇ Download</button>
  <a class="btn" href="/">⬅ Back</a>
</div>

<!-- ✅ EVERYTHING INSIDE PDF -->
<div id="pdfContent">

<h2>📦 Packing List</h2>

<div class="top-box">
  <div class="label">Order</div>
  <div class="value"><%= orderName %></div>

  <div class="label">Shipping Address</div>
  <div class="address">
    <%= shippingAddress || "No address available" %>
  </div>
</div>

<!-- ✅ ITEMS NOW INCLUDED -->
<% items.forEach(item => { %>
<div class="card">
  <div class="row">
    <div class="product"><%= item.name %></div>
    <div class="qty"><%= item.quantity %></div>
  </div>
</div>
<% }) %>

</div>

<script>
  function downloadPDF() {
    const element = document.getElementById("pdfContent");

    const opt = {
      margin: 0.3,
      filename: 'Packing_List_<%= orderName %>.pdf',
      image: { type: 'jpeg', quality: 1 },
      html2canvas: { scale: 2 },
      jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
    };

    html2pdf().set(opt).from(element).save();
  }
</script>

</body>
</html>