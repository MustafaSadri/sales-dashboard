<!DOCTYPE html>
<html>
<head>
  <title>Packing List — <%= orderName %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <style>
    :root {
      --bg: #f0f4f8;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --text: #111827;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --accent: #4f46e5;
    }
    [data-theme="dark"] {
      --bg: #0d1117; --surface: #161b22; --surface2: #21262d;
      --text: #e6edf3; --text-muted: #8b949e; --border: #30363d;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'Segoe UI', BlinkMacSystemFont, Arial, sans-serif;
      background: var(--bg); color: var(--text);
      min-height: 100vh; transition: background 0.25s, color 0.25s;
    }

    /* ── ACTION BAR (hidden on print) ── */
    .action-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 16px; background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 10;
    }
    .ab-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 8px 14px; border-radius: 9px;
      font-size: 13px; font-weight: 600; cursor: pointer;
      border: 1.5px solid var(--border);
      background: var(--surface); color: var(--text);
      text-decoration: none; transition: background 0.2s;
    }
    .ab-btn:hover { background: var(--surface2); }
    .ab-btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
    .ab-btn-primary:hover { background: #4338ca; }
    .spacer { flex: 1; }
    .theme-btn {
      width: 36px; height: 36px; border-radius: 9px;
      border: 1.5px solid var(--border);
      background: var(--surface); color: var(--text);
      font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .theme-btn:hover { background: var(--surface2); }

    /* ── SCREEN LAYOUT ── */
    .content {
      max-width: 640px; margin: 0 auto;
      padding: 20px 16px 40px;
    }

    .doc-title {
      text-align: center; font-size: 20px; font-weight: 800;
      letter-spacing: -0.3px; margin-bottom: 14px;
    }

    .header-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 14px 16px; margin-bottom: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .h-label {
      font-size: 10px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 2px;
    }
    .h-value { font-size: 15px; font-weight: 700; margin-bottom: 10px; }
    .h-address {
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: 8px; padding: 8px 10px;
      font-size: 12px; white-space: pre-line; line-height: 1.5;
      margin-bottom: 10px; color: var(--text);
    }
    .h-total {
      display: flex; justify-content: space-between; align-items: center;
      padding: 8px 0 0; border-top: 1.5px solid var(--border);
    }
    .h-total-label { font-size: 13px; font-weight: 700; }
    .h-total-value { font-size: 20px; font-weight: 800; color: var(--accent); }

    /* ITEMS */
    .items-list {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .item-row {
      display: flex; align-items: center; justify-content: space-between;
      gap: 10px; padding: 9px 14px;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    .item-row:last-child { border-bottom: none; }
    .item-row:hover { background: var(--surface2); }
    .item-num { color: var(--text-muted); font-size: 11px; min-width: 22px; flex-shrink: 0; }
    .item-name { flex: 1; line-height: 1.4; }
    .item-qty { font-weight: 700; color: var(--accent); min-width: 32px; text-align: right; flex-shrink: 0; }

    /* ── PRINT / PDF COMPACT STYLES ── */
    @media print {
      * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .action-bar { display: none !important; }
      body { background: #fff !important; color: #111 !important; font-size: 9px; }

      .content { padding: 0; max-width: 100%; }

      .doc-title { font-size: 13px; margin-bottom: 5px; text-align: center; }

      .header-card {
        padding: 5px 7px; margin-bottom: 5px;
        border-radius: 4px; box-shadow: none;
        background: #fff !important; border: 1px solid #ccc;
      }
      .h-label   { font-size: 6.5px; color: #888; margin-bottom: 1px; }
      .h-value   { font-size: 9.5px; margin-bottom: 5px; color: #111 !important; }
      .h-address {
        font-size: 8px; line-height: 1.2; padding: 3px 5px;
        margin-bottom: 5px; border-radius: 3px;
        background: #f5f5f5 !important; border: 1px solid #ddd;
        color: #111 !important; white-space: pre-line;
      }
      .h-total { padding: 4px 0 0; }
      .h-total-label { font-size: 9px; }
      .h-total-value { font-size: 11px; color: #333 !important; }

      .items-list {
        border-radius: 0; border: none;
        box-shadow: none; background: #fff !important;
      }
      .item-row {
        padding: 2px 0; font-size: 9px;
        border-bottom: 1px solid #ebebeb !important;
        page-break-inside: avoid;
        background: #fff !important;
      }
      .item-row:nth-child(even) { background: #f9f9f9 !important; }
      .item-num { font-size: 7.5px; min-width: 18px; color: #aaa; }
      .item-qty { font-size: 9px; color: #333 !important; min-width: 24px; }
    }

    /* ── PDF DOWNLOAD COMPACT (mirrors print) ── */
    .pdf-mode { padding: 0; max-width: 100%; background: #fff !important; color: #111 !important; }
    .pdf-mode .doc-title { font-size: 13px; margin-bottom: 5px; }
    .pdf-mode .header-card {
      padding: 5px 7px; margin-bottom: 5px; border-radius: 4px;
      box-shadow: none; background: #fff; border: 1px solid #ccc;
    }
    .pdf-mode .h-label   { font-size: 6.5px; color: #888; margin-bottom: 1px; }
    .pdf-mode .h-value   { font-size: 9.5px; margin-bottom: 5px; color: #111; }
    .pdf-mode .h-address { font-size: 8px; line-height: 1.2; padding: 3px 5px; margin-bottom: 5px; border-radius: 3px; background: #f5f5f5; border: 1px solid #ddd; color: #111 !important; white-space: pre-line; }
    .pdf-mode .h-total   { padding: 4px 0 0; }
    .pdf-mode .h-total-label { font-size: 9px; }
    .pdf-mode .h-total-value { font-size: 11px; color: #333; }
    .pdf-mode .items-list { border-radius: 0; border: none; box-shadow: none; background: #fff; }
    .pdf-mode .item-row  { padding: 2px 0; font-size: 9px; border-bottom: 1px solid #ebebeb; background: #fff; }
    .pdf-mode .item-row:nth-child(even) { background: #f9f9f9; }
    .pdf-mode .item-num  { font-size: 7.5px; min-width: 18px; color: #aaa; }
    .pdf-mode .item-qty  { font-size: 9px; color: #333; min-width: 24px; }
  </style>
</head>
<body>

<div class="action-bar">
  <a class="ab-btn" href="/">← Back</a>
  <button class="ab-btn" onclick="window.print()">🖨 Print</button>
  <button class="ab-btn ab-btn-primary" onclick="downloadPDF()">⬇ PDF</button>
  <div class="spacer"></div>
  <button class="theme-btn" id="themeBtn" onclick="toggleTheme()"></button>
</div>

<div class="content" id="pdfContent">

  <div class="doc-title">📦 Packing List</div>

  <div class="header-card">
    <div class="h-label">Order</div>
    <div class="h-value"><%= orderName %></div>

    <div class="h-label">Shipping Address</div>
    <div class="h-address"><%= shippingAddress || 'No address available' %></div>

    <div class="h-total">
      <span class="h-total-label">Total PCS</span>
      <span class="h-total-value"><%= items.reduce(function(s,i){return s+i.quantity;},0) %></span>
    </div>
  </div>

  <div class="items-list">
    <% items.forEach(function(item, i) { %>
    <div class="item-row">
      <span class="item-num"><%= i + 1 %></span>
      <span class="item-name"><%= item.name %></span>
      <span class="item-qty"><%= item.quantity %></span>
    </div>
    <% }); %>
  </div>

</div>

<script>
  function setIcon() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
  }
  function toggleTheme() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    var next = dark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    setIcon();
  }
  setIcon();

  function downloadPDF() {
    var el = document.getElementById('pdfContent');
    el.classList.add('pdf-mode');
    html2pdf().set({
      margin: [4, 5, 4, 5],
      filename: 'Packing_List_<%= orderName %>.pdf',
      image: { type: 'jpeg', quality: 1 },
      html2canvas: { scale: 2, useCORS: true },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    }).from(el).save().then(function() {
      el.classList.remove('pdf-mode');
    });
  }
</script>

</body>
</html>
