<!DOCTYPE html>
<html>
<head>
  <title>Create Shipment</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "San Francisco", Arial;
      background: #f5f5f7;
      color: #1d1d1f;
    }

    .container {
      padding: 20px;
      max-width: 520px;
      margin: 0 auto;
    }

    h2 {
      text-align: center;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .card {
      background: white;
      border-radius: 20px;
      padding: 18px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .label {
      color: #6e6e73;
      font-size: 14px;
      margin-top: 12px;
    }

    .value {
      font-weight: 600;
      font-size: 16px;
      margin-top: 4px;
      word-break: break-word;
    }

    .notice {
      background: #e6f4ea;
      color: #1e7e34;
      border-radius: 12px;
      padding: 10px;
      margin-top: 14px;
      font-size: 14px;
      font-weight: 600;
    }

    .passcode {
      width: 100%;
      box-sizing: border-box;
      margin-top: 8px;
      padding: 11px 12px;
      border: 1px solid #d1d1d6;
      border-radius: 12px;
      background: white;
      color: #1d1d1f;
      font: inherit;
      font-size: 16px;
      outline: none;
    }

    .passcode:focus {
      border-color: #0071e3;
      box-shadow: 0 0 0 3px rgba(0,113,227,0.12);
    }

    .error {
      color: #b00020;
      font-size: 13px;
      margin-top: 8px;
      font-weight: 600;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }

    .btn {
      flex: 1;
      text-align: center;
      background: #0071e3;
      color: white;
      padding: 11px 10px;
      border-radius: 12px;
      text-decoration: none;
      border: none;
      font: inherit;
      font-weight: 500;
      cursor: pointer;
    }

    .btn:hover {
      background: #005bb5;
    }

    .cancel {
      background: #e5e5ea;
      color: #1d1d1f;
    }

    .cancel:hover {
      background: #d1d1d6;
    }
  </style>
</head>

<body>

<div class="container">
  <h2>Create Shipment</h2>

  <div class="card">
    <div class="label">Order</div>
    <div class="value"><%= order.name %></div>

    <div class="label">Current Status</div>
    <div class="value"><%= order.status %></div>

    <div class="label">Shipment No</div>
    <div class="value"><%= order.name %></div>

    <% if (shipmentMessage) { %>
      <div class="notice"><%= shipmentMessage %></div>
      <div class="actions">
        <a class="btn" href="/?updated=1">Back</a>
      </div>
    <% } else { %>
      <form method="POST" action="/create-shipment/<%= order.id %>">
        <div class="label">Passcode</div>
        <input
          class="passcode"
          type="password"
          name="passcode"
          inputmode="numeric"
          pattern="[0-9]{4}"
          maxlength="4"
          placeholder="Enter 4 digit passcode"
          autocomplete="off"
          required
        >

        <% if (passcodeError) { %>
          <div class="error"><%= passcodeError %></div>
        <% } %>

        <div class="actions">
          <a class="btn cancel" href="/">Cancel</a>
          <button class="btn" type="submit">Create</button>
        </div>
      </form>
    <% } %>
  </div>
</div>

</body>
</html>
