<!DOCTYPE html>
<html>
<head>
  <title>Transfer Items — <%= transferName %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <style>
    :root {
      --bg: #f0f4f8;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --text: #111827;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --accent: #7c3aed;
      --radius: 14px;
    }
    [data-theme="dark"] {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #21262d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --border: #30363d;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'Segoe UI', BlinkMacSystemFont, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      transition: background 0.25s, color 0.25s;
    }

    .action-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 10;
    }
    .ab-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 8px 14px;
      border-radius: 9px;
      font-size: 13px; font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text);
      text-decoration: none;
      transition: background 0.2s;
    }
    .ab-btn:hover { background: var(--surface2); }
    .ab-btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
    .ab-btn-primary:hover { background: #6d28d9; }
    .spacer { flex: 1; }
    .theme-btn {
      width: 36px; height: 36px;
      border-radius: 9px;
      border: 1.5px solid var(--border);
      background: var(--surface); color: var(--text);
      font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .theme-btn:hover { background: var(--surface2); }

    .content {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px 16px 40px;
    }

    .page-title { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 16px; }

    .info-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      border-left: 4px solid var(--accent);
      padding: 16px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .info-label {
      font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.6px;
      color: var(--text-muted); margin-bottom: 3px;
    }
    .info-value { font-size: 15px; font-weight: 600; margin-bottom: 12px; }

    .route-row {
      display: flex; align-items: center; gap: 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 10px 12px;
      margin-bottom: 12px;
    }
    .route-side { flex: 1; }
    .route-arrow { font-size: 18px; color: var(--text-muted); flex-shrink: 0; }

    .total-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0 0;
      border-top: 1px solid var(--border);
      margin-top: 4px;
    }
    .total-label { font-size: 13px; font-weight: 600; color: var(--text-muted); }
    .total-value { font-size: 18px; font-weight: 800; color: var(--accent); }

    .section-title {
      font-size: 12px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.7px;
      color: var(--text-muted); margin-bottom: 10px;
    }

    .item-row {
      display: flex; justify-content: space-between;
      align-items: center; gap: 12px;
      padding: 11px 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      margin-bottom: 6px;
      page-break-inside: avoid;
    }
    .item-row:hover { background: var(--surface2); }
    .item-name { font-size: 14px; flex: 1; word-break: break-word; line-height: 1.4; }
    .item-qty { font-size: 15px; font-weight: 700; color: var(--accent); min-width: 36px; text-align: right; flex-shrink: 0; }

    @media print {
      .action-bar { display: none !important; }
      body { background: white !important; }
    }
  </style>
</head>
<body>

<div class="action-bar">
  <a class="ab-btn" href="/transfers">← Back</a>
  <button class="ab-btn" onclick="window.print()">🖨 Print</button>
  <button class="ab-btn ab-btn-primary" onclick="downloadPDF()">⬇ PDF</button>
  <div class="spacer"></div>
  <button class="theme-btn" id="themeBtn" onclick="toggleTheme()"></button>
</div>

<div class="content" id="pdfContent">
  <div class="page-title">⇆ Transfer Items</div>

  <div class="info-card">
    <div class="info-label">Transfer No.</div>
    <div class="info-value"><%= transferName %></div>

    <div class="route-row">
      <div class="route-side">
        <div class="info-label">From</div>
        <div style="font-size:14px;font-weight:600;"><%= source || 'N/A' %></div>
      </div>
      <div class="route-arrow">→</div>
      <div class="route-side">
        <div class="info-label">To</div>
        <div style="font-size:14px;font-weight:600;"><%= target || 'N/A' %></div>
      </div>
    </div>

    <div class="total-bar">
      <span class="total-label">Total Items</span>
      <span class="total-value"><%= items.reduce(function(s,i){return s+i.quantity;},0) %> pcs</span>
    </div>
  </div>

  <div class="section-title">Items (<%= items.length %>)</div>

  <% items.forEach(function(item) { %>
  <div class="item-row">
    <div class="item-name"><%= item.name %></div>
    <div class="item-qty"><%= item.quantity %></div>
  </div>
  <% }); %>
</div>

<script>
  function setIcon() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
  }
  function toggleTheme() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    var next = dark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    setIcon();
  }
  setIcon();

  function downloadPDF() {
    var el = document.getElementById('pdfContent');
    html2pdf().set({
      margin: 8,
      filename: 'Transfer_Items_<%= transferName %>.pdf',
      image: { type: 'jpeg', quality: 1 },
      html2canvas: { scale: 2 },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    }).from(el).save();
  }
</script>

</body>
</html>
