<!DOCTYPE html>
<html>
<head>
  <title>Transfer Items</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: -apple-system, Arial;
      background: #f5f5f7;
      padding: 10px;
    }

    h2 {
      text-align: center;
      margin-bottom: 4px;
      font-size: 16px;
    }

    .top-box {
      background: white;
      border-radius: 10px;
      padding: 6px;
      margin-bottom: 6px;
    }

    .label {
      font-size: 10px;
      color: #6e6e73;
      margin-top: 2px;
    }

    .value {
      font-weight: 600;
      font-size: 12px;
    }

    .address {
      font-size: 10px;
      white-space: pre-line;
      background: #f2f2f7;
      padding: 4px;
      border-radius: 6px;
      margin-top: 4px;
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      margin-top: 4px;
      padding: 4px 6px;
      border-top: 1px solid #ddd;
    }

    .btn-bar {
      display: flex;
      gap: 8px;
      margin: 8px 0 10px 0;
    }

    .btn {
      padding: 6px 10px;
      background: #0071e3;
      color: white;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-size: 12px;
      text-decoration: none;
    }

    .card {
      background: white;
      border-radius: 6px;
      padding: 4px 6px;
      margin-bottom: 2px;
      page-break-inside: avoid;
    }

    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .product {
      font-size: 11.5px;
      flex: 1;
      word-break: break-word;
    }

    .qty {
      font-weight: bold;
      font-size: 11.5px;
      min-width: 40px;
      text-align: right;
      padding-right: 4px;
    }

    #pdfContent {
      width: 100%;
      overflow: hidden;
      padding-right: 6px;
    }

    @media print {
      .btn-bar {
        display: none;
      }
      body {
        background: white;
      }
    }
  </style>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>

<body>

<div class="btn-bar">
  <button class="btn" onclick="window.print()">🖨️ Print</button>
  <button class="btn" onclick="downloadPDF()">⬇ Download</button>
  <a class="btn" href="/transfers">⬅ Back</a>
</div>

<div id="pdfContent">

<h2>⇆ Transfer Items</h2>

<div class="top-box">
  <div class="label">Transfer No.</div>
  <div class="value"><%= transferName %></div>

  <div class="label">Source Warehouse</div>
  <div class="address">
    <%= source || "N/A" %>
  </div>

  <div class="label">Target Warehouse</div>
  <div class="address">
    <%= target || "N/A" %>
  </div>

  <div class="total-row">
    <div><b>Total PCS</b></div>
    <div><b><%= items.reduce((sum, item) => sum + item.quantity, 0) %></b></div>
  </div>
</div>

<% items.forEach(item => { %>
<div class="card">
  <div class="row">
    <div class="product"><%= item.name %></div>
    <div class="qty"><%= item.quantity %></div>
  </div>
</div>
<% }) %>

</div>

<script>
function downloadPDF() {
  const element = document.getElementById("pdfContent");

  const opt = {
    margin: 8,
    filename: 'Transfer_Items_<%= transferName %>.pdf',
    image: { type: 'jpeg', quality: 1 },
    html2canvas: { scale: 2 },
    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };

  html2pdf().set(opt).from(element).save();
}
</script>

</body>
</html>
