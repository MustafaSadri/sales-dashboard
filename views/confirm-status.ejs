<!DOCTYPE html>
<html>
<head>
  <title>Confirm Status Change</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    :root {
      --bg: #f0f4f8;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --text: #111827;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --topbar: rgba(255,255,255,0.88);
      --accent: #4f46e5;
      --green: #10b981;
      --radius: 18px;
    }
    [data-theme="dark"] {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #21262d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --border: #30363d;
      --topbar: rgba(22,27,34,0.92);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'Segoe UI', BlinkMacSystemFont, Arial, sans-serif;
      background: var(--bg); color: var(--text);
      min-height: 100vh; transition: background 0.25s, color 0.25s;
    }
    .topbar {
      position: sticky; top: 0; z-index: 10;
      background: var(--topbar); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      height: 56px; display: flex; align-items: center; padding: 0 20px;
    }
    .topbar-inner { width: 100%; max-width: 520px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
    .topbar-title { font-size: 15px; font-weight: 700; }
    .theme-btn {
      width: 36px; height: 36px; border-radius: 9px; border: 1px solid var(--border);
      background: var(--surface); color: var(--text); font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center; transition: background 0.2s;
    }
    .theme-btn:hover { background: var(--surface2); }

    .main { max-width: 520px; margin: 0 auto; padding: 24px 16px 60px; }
    .page-title { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 20px; }

    .card {
      background: var(--surface); border-radius: var(--radius);
      border: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden;
    }
    .card-section { padding: 18px 20px; border-bottom: 1px solid var(--border); }
    .card-section:last-child { border-bottom: none; }

    .info-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text-muted); margin-bottom: 4px; }
    .info-value { font-size: 16px; font-weight: 700; word-break: break-word; }

    /* Status change arrow */
    .change-row { display: flex; align-items: center; gap: 10px; margin-top: 14px; }
    .chip { font-size: 11px; font-weight: 700; padding: 4px 11px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.4px; }
    .chip-from { background: var(--surface2); color: var(--text-muted); border: 1px solid var(--border); }
    .chip-arrow { font-size: 16px; color: var(--text-muted); }
    .chip-dispatch { background: #d1fae5; color: #065f46; }
    .chip-new      { background: #ede9fe; color: #5b21b6; }
    [data-theme="dark"] .chip-dispatch { background: #002e12; color: #6ee7b7; }
    [data-theme="dark"] .chip-new      { background: #1e0a4a; color: #c4b5fd; }

    /* ── ATTACHMENT SECTION ── */
    .attach-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px;
    }
    .attach-title { font-size: 14px; font-weight: 700; display: flex; align-items: center; gap: 7px; }
    .optional-tag {
      font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
      padding: 2px 7px; border-radius: 10px;
      background: rgba(16,185,129,0.1); color: var(--green); border: 1px solid rgba(16,185,129,0.3);
    }

    .field-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }

    .tracking-input {
      width: 100%; padding: 10px 12px;
      border: 1.5px solid var(--border); border-radius: 10px;
      background: var(--surface2); color: var(--text);
      font-family: inherit; font-size: 14px; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s; margin-bottom: 14px;
    }
    .tracking-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,0.1); background: var(--surface); }
    .tracking-input::placeholder { color: var(--text-muted); }

    /* File drop zone */
    .file-zone {
      border: 2px dashed var(--border); border-radius: 12px;
      padding: 16px; text-align: center; cursor: pointer;
      transition: border-color 0.2s, background 0.2s; position: relative;
    }
    .file-zone:hover, .file-zone.dragover { border-color: var(--accent); background: rgba(79,70,229,0.04); }
    .file-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
    .file-zone-icon { font-size: 24px; margin-bottom: 6px; }
    .file-zone-text { font-size: 13px; font-weight: 600; color: var(--text-muted); }
    .file-zone-sub  { font-size: 11px; color: var(--text-muted); margin-top: 3px; }

    /* Selected files list */
    .file-list { margin-top: 10px; display: flex; flex-direction: column; gap: 5px; }
    .file-item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 10px; border-radius: 8px;
      background: var(--surface2); border: 1px solid var(--border); font-size: 12px;
    }
    .file-item-icon { font-size: 16px; flex-shrink: 0; }
    .file-item-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 500; }
    .file-item-size { color: var(--text-muted); flex-shrink: 0; font-size: 11px; }
    .file-item-rm {
      width: 20px; height: 20px; border-radius: 50%; border: none; background: var(--border);
      color: var(--text-muted); cursor: pointer; font-size: 12px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; font-weight: 700;
    }
    .file-item-rm:hover { background: #fee2e2; color: #dc2626; }

    /* Passcode */
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-muted); margin-bottom: 8px; display: block; }
    .passcode-input {
      width: 100%; padding: 13px 14px; border: 1.5px solid var(--border); border-radius: 11px;
      background: var(--surface2); color: var(--text); font-family: inherit;
      font-size: 18px; letter-spacing: 4px; text-align: center; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .passcode-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,0.12); background: var(--surface); }
    .error-msg { margin-top: 10px; padding: 10px 14px; background: #fee2e2; color: #991b1b; border-radius: 9px; font-size: 13px; font-weight: 600; }
    [data-theme="dark"] .error-msg { background: #3a0a0a; color: #fca5a5; }

    /* Actions */
    .actions { display: flex; gap: 10px; padding: 16px 20px; background: var(--surface2); border-top: 1px solid var(--border); }
    .btn { flex: 1; text-align: center; padding: 13px 10px; border-radius: 11px; font-size: 14px; font-weight: 700; text-decoration: none; border: none; cursor: pointer; font-family: inherit; transition: opacity 0.2s, transform 0.1s; }
    .btn:active { transform: scale(0.97); }
    .btn-cancel { background: var(--surface); border: 1.5px solid var(--border); color: var(--text); }
    .btn-cancel:hover { background: var(--bg); }
    .btn-confirm { background: var(--accent); color: #fff; }
    .btn-confirm:hover { background: #4338ca; }
    .btn-dispatch { background: var(--green); color: #fff; }
    .btn-dispatch:hover { background: #059669; }
  </style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="topbar-title">📋 Confirm Status</div>
    <button class="theme-btn" id="themeBtn" onclick="toggleTheme()"></button>
  </div>
</header>

<main class="main">
  <div class="page-title">Update Order Status</div>

  <div class="card">

    <!-- Order info -->
    <div class="card-section">
      <div class="info-label">Order</div>
      <div class="info-value"><%= order.name %></div>
      <div class="change-row">
        <span class="chip chip-from"><%= order.status %></span>
        <span class="chip-arrow">→</span>
        <span class="chip <%= wantedStatus === 'DISPATCHED' ? 'chip-dispatch' : 'chip-new' %>"><%= wantedStatus %></span>
      </div>
    </div>

    <form
      method="POST"
      action="/update-status/<%= order.id %>/<%= encodeURIComponent(wantedStatus) %>"
      enctype="multipart/form-data"
      onsubmit="var b=this.querySelector('[type=submit]');b.disabled=true;b.textContent='Processing…';b.style.opacity='0.65';"
    >

      <% if (wantedStatus === 'DISPATCHED') { %>
      <!-- ── ATTACHMENT SECTION (DISPATCHED only) ── -->
      <div class="card-section">
        <div class="attach-header">
          <div class="attach-title">📎 Attachments <span class="optional-tag">Optional</span></div>
        </div>

        <!-- Tracking number -->
        <div class="field-label">Tracking Number</div>
        <input
          class="tracking-input"
          type="text"
          name="trackingNumber"
          placeholder="e.g. RU123456789CN"
          autocomplete="off"
        >

        <!-- File upload -->
        <div class="field-label">Files (photos, PDFs)</div>
        <div class="file-zone" id="fileZone">
          <input
            type="file"
            name="attachments"
            id="fileInput"
            multiple
            accept="image/*,.pdf"
            onchange="handleFiles(this.files)"
          >
          <div class="file-zone-icon">📁</div>
          <div class="file-zone-text">Tap to choose files</div>
          <div class="file-zone-sub">Photos, PDFs · max 10 MB each · up to 5 files</div>
        </div>
        <div class="file-list" id="fileList"></div>
      </div>
      <% } %>

      <!-- ── PASSCODE SECTION ── -->
      <div class="card-section">
        <label class="form-label" for="passcode">Enter 4-digit passcode</label>
        <input
          class="passcode-input"
          id="passcode"
          type="password"
          name="passcode"
          inputmode="numeric"
          pattern="[0-9]{4}"
          maxlength="4"
          placeholder="••••"
          autocomplete="off"
          autofocus
          required
        >
        <% if (passcodeError) { %><div class="error-msg">⚠️ <%= passcodeError %></div><% } %>
        <% if (statusError)   { %><div class="error-msg">⚠️ <%= statusError %></div><% } %>
      </div>

      <div class="actions">
        <a class="btn btn-cancel" href="/">Cancel</a>
        <button class="btn <%= wantedStatus === 'DISPATCHED' ? 'btn-dispatch' : 'btn-confirm' %>" type="submit">
          <%= actionLabel %>
        </button>
      </div>
    </form>

  </div>
</main>

<script>
  function setIcon() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
  }
  function toggleTheme() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    var next = dark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    setIcon();
  }
  setIcon();

  // File handling
  var selectedFiles = new DataTransfer();

  function handleFiles(newFiles) {
    for (var i = 0; i < newFiles.length; i++) {
      if (selectedFiles.files.length < 5) {
        selectedFiles.items.add(newFiles[i]);
      }
    }
    document.getElementById('fileInput').files = selectedFiles.files;
    renderFileList();
  }

  function removeFile(index) {
    var dt = new DataTransfer();
    var files = selectedFiles.files;
    for (var i = 0; i < files.length; i++) {
      if (i !== index) dt.items.add(files[i]);
    }
    selectedFiles = dt;
    document.getElementById('fileInput').files = selectedFiles.files;
    renderFileList();
  }

  function fmtSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function fileIcon(name) {
    var ext = name.split('.').pop().toLowerCase();
    if (ext === 'pdf') return '📄';
    if (['jpg','jpeg','png','gif','webp','heic'].indexOf(ext) >= 0) return '🖼';
    return '📎';
  }

  function renderFileList() {
    var list = document.getElementById('fileList');
    if (!list) return;
    list.innerHTML = '';
    var files = selectedFiles.files;
    for (var i = 0; i < files.length; i++) {
      (function(idx, f) {
        var div = document.createElement('div');
        div.className = 'file-item';
        div.innerHTML =
          '<span class="file-item-icon">' + fileIcon(f.name) + '</span>' +
          '<span class="file-item-name">' + f.name + '</span>' +
          '<span class="file-item-size">' + fmtSize(f.size) + '</span>' +
          '<button type="button" class="file-item-rm" onclick="removeFile(' + idx + ')">✕</button>';
        list.appendChild(div);
      })(i, files[i]);
    }
  }

  // Drag & drop on file zone
  var zone = document.getElementById('fileZone');
  if (zone) {
    zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', function(){ zone.classList.remove('dragover'); });
    zone.addEventListener('drop', function(e){
      e.preventDefault(); zone.classList.remove('dragover');
      handleFiles(e.dataTransfer.files);
    });
  }
</script>

</body>
</html>
