<!DOCTYPE html>
<html>
<head>
  <title>Confirm Status Change</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script>(function(){var t=localStorage.getItem('theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
  <style>
    :root {
      --bg: #f0f4f8;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --text: #111827;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --topbar: rgba(255,255,255,0.88);
      --accent: #4f46e5;
      --radius: 18px;
    }
    [data-theme="dark"] {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #21262d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --border: #30363d;
      --topbar: rgba(22,27,34,0.92);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'Segoe UI', BlinkMacSystemFont, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      transition: background 0.25s, color 0.25s;
    }

    .topbar {
      position: sticky; top: 0; z-index: 10;
      background: var(--topbar);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      height: 56px;
      display: flex; align-items: center;
      padding: 0 20px;
    }
    .topbar-inner {
      width: 100%; max-width: 480px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
    }
    .topbar-title { font-size: 15px; font-weight: 700; }

    .theme-btn {
      width: 36px; height: 36px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-size: 16px;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .theme-btn:hover { background: var(--surface2); }

    .main {
      max-width: 480px;
      margin: 0 auto;
      padding: 28px 16px 60px;
    }

    .page-title {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
    }

    .card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      overflow: hidden;
    }

    .card-section {
      padding: 20px;
      border-bottom: 1px solid var(--border);
    }
    .card-section:last-child { border-bottom: none; }

    .info-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    .info-value {
      font-size: 16px;
      font-weight: 700;
      word-break: break-word;
    }

    .change-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 16px;
    }
    .status-chip {
      font-size: 11px;
      font-weight: 700;
      padding: 5px 12px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .chip-current  { background: var(--surface2); color: var(--text-muted); border: 1px solid var(--border); }
    .chip-arrow    { font-size: 18px; color: var(--text-muted); }
    .chip-new      { background: #ede9fe; color: #5b21b6; }
    .chip-dispatch { background: #d1fae5; color: #065f46; }
    [data-theme="dark"] .chip-current  { background: var(--surface2); }
    [data-theme="dark"] .chip-new      { background: #1e0a4a; color: #c4b5fd; }
    [data-theme="dark"] .chip-dispatch { background: #002e12; color: #6ee7b7; }

    .form-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-muted);
      margin-bottom: 8px;
      display: block;
    }
    .input {
      width: 100%;
      padding: 13px 14px;
      border: 1.5px solid var(--border);
      border-radius: 11px;
      background: var(--surface2);
      color: var(--text);
      font-family: inherit;
      font-size: 18px;
      letter-spacing: 4px;
      text-align: center;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
      background: var(--surface);
    }

    .error-msg {
      margin-top: 10px;
      padding: 10px 14px;
      background: #fee2e2;
      color: #991b1b;
      border-radius: 9px;
      font-size: 13px;
      font-weight: 600;
    }
    [data-theme="dark"] .error-msg { background: #3a0a0a; color: #fca5a5; }

    .actions {
      display: flex;
      gap: 10px;
      padding: 16px 20px;
      background: var(--surface2);
      border-top: 1px solid var(--border);
    }
    .btn {
      flex: 1;
      text-align: center;
      padding: 13px 10px;
      border-radius: 11px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.2s, transform 0.1s;
    }
    .btn:active { transform: scale(0.97); }
    .btn-cancel {
      background: var(--surface);
      border: 1.5px solid var(--border);
      color: var(--text);
    }
    .btn-cancel:hover { background: var(--bg); }
    .btn-confirm { background: var(--accent); color: #fff; }
    .btn-confirm:hover { background: #4338ca; }
  </style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="topbar-title">📋 Confirm Status</div>
    <button class="theme-btn" id="themeBtn" onclick="toggleTheme()"></button>
  </div>
</header>

<main class="main">
  <div class="page-title">Update Order Status</div>

  <div class="card">
    <div class="card-section">
      <div class="info-label">Order</div>
      <div class="info-value"><%= order.name %></div>

      <div class="change-row">
        <span class="status-chip chip-current"><%= order.status %></span>
        <span class="chip-arrow">→</span>
        <span class="status-chip <%= wantedStatus === 'DISPATCHED' ? 'chip-dispatch' : 'chip-new' %>">
          <%= wantedStatus %>
        </span>
      </div>
    </div>

    <form method="POST"
          action="/update-status/<%= order.id %>/<%= encodeURIComponent(wantedStatus) %>"
          onsubmit="var b=this.querySelector('[type=submit]');b.disabled=true;b.textContent='Processing…';b.style.opacity='0.65';">
      <div class="card-section">
        <label class="form-label" for="passcode">Enter 4-digit passcode</label>
        <input
          class="input"
          id="passcode"
          type="password"
          name="passcode"
          inputmode="numeric"
          pattern="[0-9]{4}"
          maxlength="4"
          placeholder="••••"
          autocomplete="off"
          autofocus
          required
        >

        <% if (passcodeError) { %>
          <div class="error-msg">⚠️ <%= passcodeError %></div>
        <% } %>
        <% if (statusError) { %>
          <div class="error-msg">⚠️ <%= statusError %></div>
        <% } %>
      </div>

      <div class="actions">
        <a class="btn btn-cancel" href="/">Cancel</a>
        <button class="btn btn-confirm" type="submit"><%= actionLabel %></button>
      </div>
    </form>
  </div>
</main>

<script>
  function setIcon() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.getElementById('themeBtn').textContent = dark ? '☀️' : '🌙';
  }
  function toggleTheme() {
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    var next = dark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    setIcon();
  }
  setIcon();
</script>

</body>
</html>
